generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ROLES Y USUARIOS
// ============================================================
enum Rol {
  SUPERADMIN
  ADMIN_SEDE
  HOTELERO
  LIMPIEZA
  CAJERO
  LAVANDERIA
}

model Sede {
  id          Int      @id @default(autoincrement())
  nombre      String
  direccion   String?
  telefono    String?
  activa      Boolean  @default(true)
  esPrincipal Boolean  @default(false)
  creadaEn    DateTime @default(now())

  usuarios          Usuario[]
  pisos             Piso[]
  habitaciones      Habitacion[]
  productos         Producto[]
  productosLimpieza ProductoLimpieza[]
  implementos       Implemento[]
  tiposImplemento   TipoImplemento[]
  alquileres        Alquiler[]
  tareasLimpieza    TareaLimpieza[]
  turnosCaja        TurnoCaja[]
  ventas            Venta[]
  mensajes          Mensaje[]
  anulacionRequests AnulacionRequest[]
  transferenciasOrigen  TransferenciaSede[] @relation("TransferenciaOrigen")
  transferenciasDestino TransferenciaSede[] @relation("TransferenciaDestino")
  reservasGrupales  ReservaGrupal[]
  documentos        Documento[]
  personal          Personal[]
  transferenciasPersonalDesde TransferenciaPersonal[] @relation("TPDesde")
  transferenciasPersonalHasta TransferenciaPersonal[] @relation("TPHasta")
  sunatSeries       SunatSerie[]
}

// ============================================================
// SERIES SUNAT POR SEDE
// Cada sede tiene sus propias series (B003 para sede 1, B004 para
// sede 2, etc.) con su correlativo independiente. El admin de la
// sede registra el último correlativo conocido (lo ve en NubeFact)
// y el sistema incrementa atómicamente desde ahí.
// ============================================================
enum TipoComprobanteSerie {
  BOLETA
  FACTURA
}

model SunatSerie {
  id                 Int                  @id @default(autoincrement())
  sedeId             Int
  sede               Sede                 @relation(fields: [sedeId], references: [id])
  tipo               TipoComprobanteSerie
  serie              String               // ej. "B003", "F001" (4 chars exactos)
  ultimoCorrelativo  Int                  @default(0)
  activa             Boolean              @default(true)
  // Marca como serie por defecto del par (sedeId, tipo). Solo una activa
  // por (sede, tipo) puede ser predeterminada en cualquier momento.
  esPredeterminada   Boolean              @default(false)
  notas              String?
  creadoEn           DateTime             @default(now())
  actualizadoEn      DateTime             @updatedAt

  @@unique([sedeId, serie])
  @@index([sedeId, tipo, activa])
}

model Usuario {
  id           Int      @id @default(autoincrement())
  sedeId       Int?
  sede         Sede?    @relation(fields: [sedeId], references: [id])
  nombre       String
  username     String   @unique
  email        String?  @unique
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  alquileresCreados    Alquiler[]        @relation("AlquilerCreadoPor")
  alquileresAnulados   Alquiler[]        @relation("AlquilerAnuladoPor")
  alquileresCobrados   Alquiler[]        @relation("AlquilerCobradoPor")
  pagosAlquilerCreados PagoAlquiler[]    @relation("PagoCreadoPor")
  tareasAsignadas      TareaLimpieza[]   @relation("TareaAsignadaA")
  turnosCaja           TurnoCaja[]
  movimientosStock     MovimientoStock[]
  ventasCreadas        Venta[]           @relation("VentaCreadaPor")
  ventasAnuladas       Venta[]           @relation("VentaAnuladaPor")
  mensajesEnviados     Mensaje[]         @relation("MensajeFrom")
  mensajesRecibidos    Mensaje[]         @relation("MensajeTo")
  anulacionesSolicitadas AnulacionRequest[] @relation("AnuReqSolic")
  anulacionesAprobadas   AnulacionRequest[] @relation("AnuReqAprob")
  transferenciasCreadas   TransferenciaSede[] @relation("TransferenciaCreada")
  transferenciasRecibidas TransferenciaSede[] @relation("TransferenciaRecibida")
  reservasGrupalesCreadas  ReservaGrupal[] @relation("ReservaGrupalCreadaPor")
  reservasGrupalesCobradas ReservaGrupal[] @relation("ReservaGrupalCobradaPor")
  auditLogs                AuditLog[]
  personalRecord           Personal?
  transferenciasPersonalEjecutadas TransferenciaPersonal[] @relation("TPTransferidoPor")
  movimientosImplemento    MovimientoImplemento[]

  @@index([sedeId])
}

// ============================================================
// HABITACIONES
// ============================================================
enum EstadoHabitacion {
  DISPONIBLE
  OCUPADA
  ALISTANDO
  MANTENIMIENTO
  FUERA_SERVICIO
}

model Piso {
  id           Int      @id @default(autoincrement())
  sedeId       Int
  sede         Sede     @relation(fields: [sedeId], references: [id])
  numero       Int
  nombre       String?
  creadoEn     DateTime @default(now())

  habitaciones Habitacion[]

  @@unique([sedeId, numero])
  @@index([sedeId])
}

model Habitacion {
  id              Int               @id @default(autoincrement())
  sedeId          Int
  sede            Sede              @relation(fields: [sedeId], references: [id])
  pisoId          Int
  piso            Piso              @relation(fields: [pisoId], references: [id])
  numero          String
  descripcion     String?
  caracteristicas String?
  precioHora      Decimal           @db.Decimal(10, 2)
  precioNoche     Decimal           @db.Decimal(10, 2)
  estado          EstadoHabitacion  @default(DISPONIBLE)
  activa          Boolean           @default(true)
  creadoEn        DateTime          @default(now())

  alquileres      Alquiler[]
  tareasLimpieza  TareaLimpieza[]
  fotos           FotoHabitacion[]
  implementoUnidades ImplementoUnidad[]

  @@unique([sedeId, numero])
  @@index([sedeId, estado])
}

// Fotos de habitación. orden 1-4 = principales (se muestran en tarjeta),
// orden 5+ = extras (solo galería).
model FotoHabitacion {
  id            Int        @id @default(autoincrement())
  habitacionId  Int
  habitacion    Habitacion @relation(fields: [habitacionId], references: [id], onDelete: Cascade)
  path          String
  orden         Int        @default(99)
  creadoEn      DateTime   @default(now())

  @@index([habitacionId, orden])
}

// ============================================================
// PRODUCTOS (consumibles para venta)
// ============================================================
model Producto {
  id          Int      @id @default(autoincrement())
  sedeId      Int
  sede        Sede     @relation(fields: [sedeId], references: [id])
  nombre      String
  descripcion String?
  precio      Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  stockMinimo Int      @default(0)
  activo      Boolean  @default(true)
  /// Si está marcado, este producto puede darse como cortesía
  /// (descuenta stock pero no se cobra al alquiler).
  esCortesia  Boolean  @default(false)
  creadoEn    DateTime @default(now())

  consumos    ConsumoProducto[]
  movimientos MovimientoStock[]
  itemsVenta  ItemVenta[]
  transferenciasOrigen  TransferenciaItem[] @relation("TransferenciaItemOrigen")
  transferenciasDestino TransferenciaItem[] @relation("TransferenciaItemDestino")

  @@index([sedeId])
}

// ============================================================
// PRODUCTOS DE LIMPIEZA
// ============================================================
model ProductoLimpieza {
  id          Int      @id @default(autoincrement())
  sedeId      Int
  sede        Sede     @relation(fields: [sedeId], references: [id])
  nombre      String
  descripcion String?
  stock       Int      @default(0)
  stockMinimo Int      @default(0)
  unidad      String   @default("unidad")
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  usos        UsoProductoLimpieza[]

  @@index([sedeId])
}

// ============================================================
// ALQUILERES
// ============================================================
enum EstadoAlquiler {
  ACTIVO
  FINALIZADO
  ANULADO
}

enum MetodoPago {
  EFECTIVO
  VISA
  MASTERCARD
  YAPE
  PLIN
  OTRO
}

model Alquiler {
  id              Int             @id @default(autoincrement())
  sedeId          Int
  sede            Sede            @relation(fields: [sedeId], references: [id])
  habitacionId    Int
  habitacion      Habitacion      @relation(fields: [habitacionId], references: [id])
  turnoCajaId     Int?
  turnoCaja       TurnoCaja?      @relation(fields: [turnoCajaId], references: [id])

  // Si forma parte de una reserva corporativa/grupal
  reservaGrupalId Int?
  reservaGrupal   ReservaGrupal?  @relation(fields: [reservaGrupalId], references: [id])

  clienteNombre   String
  clienteDni      String
  clienteTelefono String?
  clienteFechaNacimiento DateTime?

  // Datos fiscales (para FACTURA con RUC)
  tipoComprobante         String?  // 'BOLETA' (default) o 'FACTURA'
  clienteRuc              String?
  clienteRazonSocial      String?
  clienteDireccionFiscal  String?

  fechaIngreso    DateTime
  fechaSalida     DateTime
  fechaSalidaReal DateTime?

  precioHabitacion Decimal        @db.Decimal(10, 2)
  totalProductos   Decimal        @db.Decimal(10, 2) @default(0)
  total            Decimal        @db.Decimal(10, 2)
  metodoPago       MetodoPago
  notas            String?

  estado          EstadoAlquiler  @default(ACTIVO)
  motivoAnulacion String?
  anuladoEn       DateTime?
  anuladoPorId    Int?
  anuladoPor      Usuario?        @relation("AlquilerAnuladoPor", fields: [anuladoPorId], references: [id])

  // Flags de operación diaria
  pagado          Boolean         @default(true)  // true = totalmente pagado
  montoPagado     Decimal         @db.Decimal(10, 2) @default(0)  // acumulado (puede ser parcial)
  pagadoEn        DateTime?
  turnoPagoId     Int?                            // turno del último cobro
  turnoPago       TurnoCaja?      @relation("AlquilerTurnoPago", fields: [turnoPagoId], references: [id])
  cobradoPorId    Int?
  cobradoPor      Usuario?        @relation("AlquilerCobradoPor", fields: [cobradoPorId], references: [id])

  amenitiesEntregados Boolean     @default(false) // chocolates/bienvenida
  amenitiesNotas      String?
  conCochera          Boolean     @default(false) // huésped trae auto y usa cochera

  creadoPorId     Int
  creadoPor       Usuario         @relation("AlquilerCreadoPor", fields: [creadoPorId], references: [id])
  creadoEn        DateTime        @default(now())

  consumos        ConsumoProducto[]
  anulacionRequests AnulacionRequest[]
  pagos           PagoAlquiler[]
  implementos     AsignacionImplemento[]

  // ── Facturación electrónica SUNAT (vía NubeFact) ─────────
  /// Si el cajero marcó "deseo emitir comprobante electrónico" al crear/cobrar.
  /// Por defecto false. Sin este flag, el alquiler NO se emite a SUNAT.
  deseaEmitirSunat   Boolean   @default(false)
  sunatEmitido       Boolean   @default(false)
  sunatAceptada      Boolean?
  sunatSerie         String?
  sunatNumero        Int?
  sunatEnlace        String?
  sunatEnlacePdf     String?
  sunatEnlaceXml     String?
  sunatEnlaceCdr     String?
  sunatHash          String?
  sunatQrCadena      String?
  sunatResponseCode  String?
  sunatDescripcion   String?
  sunatEmitidoEn     DateTime?
  sunatAnulada       Boolean   @default(false)
  sunatAnuladaEn     DateTime?

  @@index([sedeId, estado])
  @@index([habitacionId])
  @@index([turnoCajaId])
  @@index([reservaGrupalId])
  @@index([sunatSerie, sunatNumero])
}

model ReservaGrupal {
  id                     Int        @id @default(autoincrement())
  sedeId                 Int
  sede                   Sede       @relation(fields: [sedeId], references: [id])
  turnoCajaId            Int?
  turnoCaja              TurnoCaja? @relation(fields: [turnoCajaId], references: [id])

  // Datos de la empresa (siempre FACTURA con RUC)
  clienteRuc             String
  clienteRazonSocial     String
  clienteDireccionFiscal String?
  contactoNombre         String?
  contactoTelefono       String?

  fechaIngreso           DateTime
  fechaSalida            DateTime

  total                  Decimal    @db.Decimal(10, 2)
  metodoPago             MetodoPago
  notas                  String?
  estado                 EstadoAlquiler @default(ACTIVO)

  creadoPorId            Int
  creadoPor              Usuario    @relation("ReservaGrupalCreadaPor", fields: [creadoPorId], references: [id])
  creadoEn               DateTime   @default(now())

  // ── Cobro consolidado (1 pago por las N habitaciones) ──
  pagado                 Boolean    @default(false)
  montoPagado            Decimal    @default(0) @db.Decimal(10, 2)
  pagadoEn               DateTime?
  cobradoPorId           Int?
  cobradoPor             Usuario?   @relation("ReservaGrupalCobradaPor", fields: [cobradoPorId], references: [id])
  turnoPagoId            Int?
  turnoPago              TurnoCaja? @relation("ReservaGrupalTurnoPago", fields: [turnoPagoId], references: [id])

  // ── Factura electrónica consolidada (1 sola con N líneas) ──
  sunatEmitido           Boolean    @default(false)
  sunatAceptada          Boolean?
  sunatSerie             String?
  sunatNumero            Int?
  sunatEnlace            String?
  sunatEnlacePdf         String?
  sunatEnlaceXml         String?
  sunatEnlaceCdr         String?
  sunatHash              String?
  sunatQrCadena          String?
  sunatResponseCode      String?
  sunatDescripcion       String?
  sunatEmitidoEn         DateTime?

  alquileres             Alquiler[]

  @@index([sedeId, estado])
  @@index([clienteRuc])
}

model ConsumoProducto {
  id           Int       @id @default(autoincrement())
  alquilerId   Int
  alquiler     Alquiler  @relation(fields: [alquilerId], references: [id], onDelete: Cascade)
  productoId   Int
  producto     Producto  @relation(fields: [productoId], references: [id])
  cantidad     Int
  precioUnit   Decimal   @db.Decimal(10, 2)
  subtotal     Decimal   @db.Decimal(10, 2)
  /// Si true: el producto se entregó como cortesía. Descuenta del stock
  /// pero NO se cobra al alquiler (subtotal = 0).
  esCortesia   Boolean   @default(false)
  creadoEn     DateTime  @default(now())

  @@index([alquilerId])
  @@index([productoId])
}

// ============================================================
// IMPLEMENTOS (toallas, sábanas, controles, etc.)
// Préstamos por alquiler: se entregan y deben devolverse al cerrar.
// ============================================================
model Implemento {
  id              Int       @id @default(autoincrement())
  sedeId          Int
  sede            Sede      @relation(fields: [sedeId], references: [id])
  nombre          String
  descripcion     String?
  /// Stock total en posesión del hotel (incluye los que están afuera prestados).
  stockTotal      Int       @default(0)
  /// Disponible AHORA para entregar (stockTotal - prestados sin devolver).
  stockDisponible Int       @default(0)
  activo          Boolean   @default(true)
  creadoEn        DateTime  @default(now())
  actualizadoEn   DateTime  @updatedAt

  asignaciones    AsignacionImplemento[]

  @@index([sedeId, activo])
}

model AsignacionImplemento {
  id              Int        @id @default(autoincrement())
  alquilerId      Int
  alquiler        Alquiler   @relation(fields: [alquilerId], references: [id], onDelete: Cascade)
  implementoId    Int
  implemento      Implemento @relation(fields: [implementoId], references: [id])
  cantidad        Int        @default(1)
  fechaAsignacion DateTime   @default(now())
  /// Si NULL: aún está afuera. Si tiene fecha: ya fue devuelto.
  fechaDevolucion DateTime?
  /// Si se devolvió con faltantes/dañados (informativo).
  notas           String?

  @@index([alquilerId])
  @@index([implementoId, fechaDevolucion])
}

// ============================================================
// STOCK (historial)
// ============================================================
enum TipoMovimiento {
  ENTRADA
  SALIDA_VENTA
  SALIDA_LIMPIEZA
  SALIDA_CORTESIA
  AJUSTE
  ANULACION
  TRANSFERENCIA_SALIDA
  TRANSFERENCIA_ENTRADA
}

enum EstadoTransferencia {
  ENVIADA
  RECIBIDA
  RECHAZADA
  CANCELADA
}

model TransferenciaSede {
  id              Int                  @id @default(autoincrement())
  sedeOrigenId    Int
  sedeOrigen      Sede                 @relation("TransferenciaOrigen", fields: [sedeOrigenId], references: [id])
  sedeDestinoId   Int
  sedeDestino     Sede                 @relation("TransferenciaDestino", fields: [sedeDestinoId], references: [id])

  estado          EstadoTransferencia  @default(ENVIADA)
  notas           String?

  creadoPorId     Int
  creadoPor       Usuario              @relation("TransferenciaCreada", fields: [creadoPorId], references: [id])
  creadoEn        DateTime             @default(now())

  recibidoPorId   Int?
  recibidoPor     Usuario?             @relation("TransferenciaRecibida", fields: [recibidoPorId], references: [id])
  recibidoEn      DateTime?

  motivoRechazo   String?

  items           TransferenciaItem[]

  @@index([sedeOrigenId, estado])
  @@index([sedeDestinoId, estado])
}

model TransferenciaItem {
  id               Int               @id @default(autoincrement())
  transferenciaId  Int
  transferencia    TransferenciaSede @relation(fields: [transferenciaId], references: [id], onDelete: Cascade)

  productoOrigenId  Int
  productoOrigen    Producto          @relation("TransferenciaItemOrigen", fields: [productoOrigenId], references: [id])

  productoDestinoId Int?
  productoDestino   Producto?         @relation("TransferenciaItemDestino", fields: [productoDestinoId], references: [id])

  nombreProducto   String
  precio           Decimal           @db.Decimal(10, 2)
  cantidad         Int

  @@index([transferenciaId])
}

// Historial de cobros individuales de un alquiler.
// Soporta pagos parciales: un mismo alquiler puede tener múltiples PagoAlquiler
// (ej. 20 en turno1 + 20 en turno2 = total 40). Cada cierre de caja suma los
// PagoAlquiler con su propio turnoCajaId.
model PagoAlquiler {
  id           Int        @id @default(autoincrement())
  alquilerId   Int
  alquiler     Alquiler   @relation(fields: [alquilerId], references: [id], onDelete: Cascade)
  turnoCajaId  Int
  turnoCaja    TurnoCaja  @relation("PagoTurno", fields: [turnoCajaId], references: [id])
  usuarioId    Int
  usuario      Usuario    @relation("PagoCreadoPor", fields: [usuarioId], references: [id])
  monto        Decimal    @db.Decimal(10, 2)
  metodoPago   MetodoPago
  fecha        DateTime   @default(now())

  @@index([alquilerId])
  @@index([turnoCajaId])
}

model MovimientoStock {
  id          Int              @id @default(autoincrement())
  productoId  Int?
  producto    Producto?        @relation(fields: [productoId], references: [id])
  tipo        TipoMovimiento
  cantidad    Int
  referencia  String?
  usuarioId   Int
  usuario     Usuario          @relation(fields: [usuarioId], references: [id])
  creadoEn    DateTime         @default(now())

  @@index([productoId])
}

// ============================================================
// LIMPIEZA
// ============================================================
enum EstadoTareaLimpieza {
  PENDIENTE
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

model TareaLimpieza {
  id             Int                 @id @default(autoincrement())
  sedeId         Int
  sede           Sede                @relation(fields: [sedeId], references: [id])
  habitacionId   Int
  habitacion     Habitacion          @relation(fields: [habitacionId], references: [id])
  asignadaAId    Int?
  asignadaA      Usuario?            @relation("TareaAsignadaA", fields: [asignadaAId], references: [id])

  estado         EstadoTareaLimpieza @default(PENDIENTE)
  iniciadaEn     DateTime?
  completadaEn   DateTime?
  notas          String?

  creadaEn       DateTime            @default(now())

  fotos          FotoLimpieza[]
  productosUsados UsoProductoLimpieza[]
  movimientosImplemento MovimientoImplemento[]

  @@index([sedeId, estado])
  @@index([asignadaAId])
}

model FotoLimpieza {
  id         Int           @id @default(autoincrement())
  tareaId    Int
  tarea      TareaLimpieza @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  path       String
  subidaEn   DateTime      @default(now())

  @@index([tareaId])
}

model UsoProductoLimpieza {
  id          Int              @id @default(autoincrement())
  tareaId     Int
  tarea       TareaLimpieza    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  productoId  Int
  producto    ProductoLimpieza @relation(fields: [productoId], references: [id])
  cantidad    Int
  creadoEn    DateTime         @default(now())

  @@index([tareaId])
}

// ============================================================
// CAJA POR TURNO
// ============================================================
enum EstadoTurno {
  ABIERTO
  CERRADO
}

model TurnoCaja {
  id             Int         @id @default(autoincrement())
  sedeId         Int
  sede           Sede        @relation(fields: [sedeId], references: [id])
  usuarioId      Int
  usuario        Usuario     @relation(fields: [usuarioId], references: [id])

  abiertoEn      DateTime    @default(now())
  cerradoEn      DateTime?
  estado         EstadoTurno @default(ABIERTO)

  totalEfectivo  Decimal     @db.Decimal(10, 2) @default(0)
  totalVisa      Decimal     @db.Decimal(10, 2) @default(0)
  totalMaster    Decimal     @db.Decimal(10, 2) @default(0)
  totalYape      Decimal     @db.Decimal(10, 2) @default(0)
  totalPlin      Decimal     @db.Decimal(10, 2) @default(0)
  totalOtro      Decimal     @db.Decimal(10, 2) @default(0)
  totalGeneral   Decimal     @db.Decimal(10, 2) @default(0)
  notas          String?

  alquileres     Alquiler[]
  alquileresCobrados Alquiler[] @relation("AlquilerTurnoPago")
  ventas         Venta[]
  reservasGrupales ReservaGrupal[]
  reservasGrupalesCobradas ReservaGrupal[] @relation("ReservaGrupalTurnoPago")
  pagosAlquiler  PagoAlquiler[] @relation("PagoTurno")

  @@index([sedeId, estado])
  @@index([usuarioId])
}

// ============================================================
// VENTA DIRECTA DE PRODUCTOS (sin alquiler)
// ============================================================
enum EstadoVenta {
  ACTIVA
  ANULADA
}

model Venta {
  id               Int         @id @default(autoincrement())
  sedeId           Int
  sede             Sede        @relation(fields: [sedeId], references: [id])
  turnoCajaId      Int
  turnoCaja        TurnoCaja   @relation(fields: [turnoCajaId], references: [id])

  usuarioId        Int
  usuario          Usuario     @relation("VentaCreadaPor", fields: [usuarioId], references: [id])

  metodoPago       MetodoPago
  total            Decimal     @db.Decimal(10, 2)
  notas            String?

  estado           EstadoVenta @default(ACTIVA)
  motivoAnulacion  String?
  anuladoEn        DateTime?
  anuladoPorId     Int?
  anuladoPor       Usuario?    @relation("VentaAnuladaPor", fields: [anuladoPorId], references: [id])

  creadoEn         DateTime    @default(now())
  items            ItemVenta[]

  // ── Facturación electrónica SUNAT (vía NubeFact) ─────────
  sunatEmitido       Boolean   @default(false)
  sunatAceptada      Boolean?
  sunatSerie         String?
  sunatNumero        Int?
  sunatEnlace        String?
  sunatEnlacePdf     String?
  sunatEnlaceXml     String?
  sunatEnlaceCdr     String?
  sunatHash          String?
  sunatQrCadena      String?
  sunatResponseCode  String?
  sunatDescripcion   String?
  sunatEmitidoEn     DateTime?
  sunatAnulada       Boolean   @default(false)
  sunatAnuladaEn     DateTime?

  @@index([sedeId, estado])
  @@index([turnoCajaId])
  @@index([sunatSerie, sunatNumero])
}

model ItemVenta {
  id          Int      @id @default(autoincrement())
  ventaId     Int
  venta       Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId  Int
  producto    Producto @relation(fields: [productoId], references: [id])
  cantidad    Int
  precioUnit  Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  creadoEn    DateTime @default(now())

  @@index([ventaId])
  @@index([productoId])
}

// ============================================================
// CHAT & ANULACIONES
// ============================================================
model Mensaje {
  id        Int      @id @default(autoincrement())
  sedeId    Int
  sede      Sede     @relation(fields: [sedeId], references: [id])
  fromId    Int
  from      Usuario  @relation("MensajeFrom", fields: [fromId], references: [id])
  toId      Int
  to        Usuario  @relation("MensajeTo", fields: [toId], references: [id])
  texto     String
  tipo      String   @default("TEXTO")
  metadata  Json?
  leido     Boolean  @default(false)
  leidoEn   DateTime?
  creadoEn  DateTime @default(now())

  @@index([toId, leido])
  @@index([fromId, toId, creadoEn])
  @@index([sedeId])
}

model AnulacionRequest {
  id             Int       @id @default(autoincrement())
  sedeId         Int
  sede           Sede      @relation(fields: [sedeId], references: [id])
  alquilerId     Int
  alquiler       Alquiler  @relation(fields: [alquilerId], references: [id])
  solicitanteId  Int
  solicitante    Usuario   @relation("AnuReqSolic", fields: [solicitanteId], references: [id])
  motivo         String
  estado         String    @default("PENDIENTE")
  respuestaAdmin String?
  aprobadorId    Int?
  aprobador      Usuario?  @relation("AnuReqAprob", fields: [aprobadorId], references: [id])
  respondidoEn   DateTime?
  creadoEn       DateTime  @default(now())

  @@index([sedeId, estado])
  @@index([solicitanteId])
}

// ============================================================
// CONFIG (singleton id=1) — datos empresa + tokens API externas
// ============================================================
model AppConfig {
  id                Int      @id @default(1)
  empresaNombre     String?
  empresaRuc        String?
  empresaDireccion  String?
  empresaTelefono   String?
  empresaEmail      String?
  logoPath          String?
  apiDniToken       String?
  apiRucToken       String?
  apiDniUrl         String   @default("https://dniruc.apisperu.com/api/v1/dni")
  apiRucUrl         String   @default("https://dniruc.apisperu.com/api/v1/ruc")
  // Duración de la sesión en días (controla expiresIn del JWT al login)
  sessionTtlDays    Int      @default(30)

  // ── Facturación electrónica (NubeFact / PSE) ─────────────
  nubefactRuta            String? // URL única del cliente (api.nubefact.com o api.pse.pe reseller)
  nubefactToken           String? // Token de autenticación (puede ser UUID o JWT)
  nubefactSerieFactura    String   @default("F001")
  nubefactSerieBoleta     String   @default("B001")
  nubefactSerieNotaCred   String   @default("F001") // mismo que la factura asociada por defecto
  nubefactSerieNotaDeb    String   @default("F001")
  nubefactIgvHospedaje    Decimal  @default(10.5) @db.Decimal(5, 2) // IGV reducido hospedaje
  nubefactIgvProductos    Decimal  @default(18)   @db.Decimal(5, 2) // IGV general

  actualizadoEn     DateTime @updatedAt
  creadoEn          DateTime @default(now())
}

// ============================================================
// DOCUMENTOS — archivos del establecimiento con vencimiento
// ============================================================
enum TipoDocumento {
  PDF
  IMAGEN
  OTRO
}

model Documento {
  id              Int             @id @default(autoincrement())
  sedeId          Int?
  sede            Sede?           @relation(fields: [sedeId], references: [id])
  nombre          String
  descripcion     String?
  tipo            TipoDocumento   @default(PDF)
  archivoPath     String          // ruta relativa /uploads/documentos/...
  archivoNombre   String?         // nombre original del archivo
  fechaEmision    DateTime?
  fechaVencimiento DateTime?
  alertaDiasAntes Int             @default(30)
  creadoPorId     Int?
  creadoEn        DateTime        @default(now())
  actualizadoEn   DateTime        @updatedAt

  @@index([sedeId])
  @@index([fechaVencimiento])
}

// ============================================================
// PERSONAL — empleados con datos completos
// ============================================================
model Personal {
  id                 Int       @id @default(autoincrement())
  sedeId             Int?
  sede               Sede?     @relation(fields: [sedeId], references: [id])
  transferencias     TransferenciaPersonal[]

  dni                String    @unique
  nombre             String
  apellidoPaterno    String
  apellidoMaterno    String?

  fotoPerfil         String?   // path
  fotoDniFrente      String?
  fotoDniReverso     String?

  fechaNacimiento    DateTime?
  fechaIngreso       DateTime  @default(now())
  correo             String?
  telefono           String?
  direccion          String?
  cargo              String?
  notas              String?

  activo             Boolean   @default(true)

  // Vínculo opcional con un usuario del sistema
  usuarioId          Int?      @unique
  usuario            Usuario?  @relation(fields: [usuarioId], references: [id])

  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt

  @@index([sedeId])
  @@index([activo])
}

// ============================================================
// TRANSFERENCIAS DE PERSONAL ENTRE SEDES
// ============================================================
model TransferenciaPersonal {
  id               Int       @id @default(autoincrement())
  personalId       Int
  personal         Personal  @relation(fields: [personalId], references: [id], onDelete: Cascade)

  desdeSedeId      Int?
  desdeSede        Sede?     @relation("TPDesde", fields: [desdeSedeId], references: [id])
  hastaSedeId      Int
  hastaSede        Sede      @relation("TPHasta", fields: [hastaSedeId], references: [id])

  motivo           String
  fechaEfectiva    DateTime  @default(now())
  transferidoPorId Int
  transferidoPor   Usuario   @relation("TPTransferidoPor", fields: [transferidoPorId], references: [id])

  creadoEn         DateTime  @default(now())

  @@index([personalId, fechaEfectiva])
  @@index([hastaSedeId])
}

// ============================================================
// AUDITORIA — registro de acciones y logins
// ============================================================
model AuditLog {
  id          BigInt   @id @default(autoincrement())
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  username    String?  // desnormalizado (por si borran el usuario)
  rol         String?
  sedeId      Int?

  accion      String   // LOGIN, LOGOUT, LOGIN_FAIL, CREATE, UPDATE, DELETE, CUSTOM, etc
  recurso     String?  // 'producto', 'habitacion', 'alquiler', 'caja', ...
  recursoId   String?  // id del recurso afectado (stringify)
  metodo      String?  // GET, POST, PATCH, PUT, DELETE
  path        String?  // /api/productos/:id
  ip          String?
  userAgent   String?
  detalle     Json?    // body de la request u otros detalles (opcional)
  ok          Boolean  @default(true)
  statusCode  Int?
  duracionMs  Int?

  creadoEn    DateTime @default(now())

  @@index([usuarioId, creadoEn])
  @@index([accion, creadoEn])
  @@index([recurso, recursoId])
  @@index([creadoEn])
}

// ============================================================
// IMPLEMENTOS POR HABITACIÓN (nuevo modelo, reemplaza al viejo)
//
// Cada habitación tiene un set de implementos individuales (cada
// toalla, sábana, control TV con código único). Estados:
//   EN_HABITACION  → en su habitación (default)
//   EN_TRANSITO    → siendo llevada a lavandería (limpieza la marcó)
//   EN_LAVANDERIA  → lavándose, fuera de la habitación
//   PERDIDO        → marcado por admin si no aparece
//
// Flujo típico:
// 1. Admin crea TipoImplemento por sede (ej. "Toalla blanca grande")
// 2. Admin crea ImplementoUnidad con código único y la asigna a hab 102
// 3. Cliente se va → habitación pasa a ALISTANDO
// 4. Limpiadora completa la tarea y marca qué unidades van a lavandería
// 5. Esas unidades pasan a EN_TRANSITO → EN_LAVANDERIA
// 6. Admin/hotelero confirma desde la web cuando vuelven limpias
//    → vuelven a EN_HABITACION (a su habitación original)
// ============================================================

enum EstadoImplementoUnidad {
  /// Recién creado o devuelto al stock central, sin habitación asignada.
  SIN_ASIGNAR
  EN_HABITACION
  EN_TRANSITO
  /// Sucio: limpieza lo marcó para lavar, en la lavandería esperando turno.
  EN_LAVANDERIA
  /// Ya lavado por la lavandería, esperando entregarse a las habitaciones.
  LAVADO
  PERDIDO
}

/// Catálogo de tipos de implemento por sede (Toalla, Sábana, Control...)
model TipoImplemento {
  id            Int      @id @default(autoincrement())
  sedeId        Int
  sede          Sede     @relation(fields: [sedeId], references: [id])
  nombre        String
  /// Emoji/icono visual opcional (🧖 toalla, 🛏️ sábana, 📺 control)
  icono         String?
  /// Color de chip en la UI (hex sin #, ej "8b5cf6")
  color         String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())

  unidades      ImplementoUnidad[]

  @@unique([sedeId, nombre])
  @@index([sedeId, activo])
}

/// Cada pieza individual con código único asignada a una habitación
model ImplementoUnidad {
  id              Int                    @id @default(autoincrement())
  tipoId          Int
  tipo            TipoImplemento         @relation(fields: [tipoId], references: [id])
  /// Código único impreso/etiquetado (ej. "TBG-047", "SAB-012")
  codigo          String                 @unique
  /// Habitación a la que PERTENECE (su "casa"). Nullable: cuando se
  /// crea recién o vuelve al stock central, no tiene habitación. El
  /// admin la asigna después con asignar-habitacion.
  habitacionId    Int?
  habitacion      Habitacion?            @relation(fields: [habitacionId], references: [id])
  estado          EstadoImplementoUnidad @default(SIN_ASIGNAR)
  notas           String?
  activo          Boolean                @default(true)
  creadoEn        DateTime               @default(now())
  actualizadoEn   DateTime               @updatedAt

  movimientos     MovimientoImplemento[]

  @@index([habitacionId, estado])
  @@index([tipoId, estado])
  @@index([estado])
}

/// Historial de cambios de estado de cada unidad (auditoría completa)
model MovimientoImplemento {
  id               Int                    @id @default(autoincrement())
  unidadId         Int
  unidad           ImplementoUnidad       @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  estadoAnterior   EstadoImplementoUnidad
  estadoNuevo      EstadoImplementoUnidad
  usuarioId        Int?
  usuario          Usuario?               @relation(fields: [usuarioId], references: [id])
  /// Si el cambio fue por una limpieza, link a la tarea
  tareaLimpiezaId  Int?
  tareaLimpieza    TareaLimpieza?         @relation(fields: [tareaLimpiezaId], references: [id], onDelete: SetNull)
  notas            String?
  fecha            DateTime               @default(now())

  @@index([unidadId, fecha])
  @@index([fecha])
}
