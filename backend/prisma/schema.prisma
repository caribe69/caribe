generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ROLES Y USUARIOS
// ============================================================
enum Rol {
  SUPERADMIN
  ADMIN_SEDE
  HOTELERO
  LIMPIEZA
  CAJERO
}

model Sede {
  id          Int      @id @default(autoincrement())
  nombre      String
  direccion   String?
  telefono    String?
  activa      Boolean  @default(true)
  esPrincipal Boolean  @default(false)
  creadaEn    DateTime @default(now())

  usuarios          Usuario[]
  pisos             Piso[]
  habitaciones      Habitacion[]
  productos         Producto[]
  productosLimpieza ProductoLimpieza[]
  alquileres        Alquiler[]
  tareasLimpieza    TareaLimpieza[]
  turnosCaja        TurnoCaja[]
  ventas            Venta[]
  mensajes          Mensaje[]
  anulacionRequests AnulacionRequest[]
  transferenciasOrigen  TransferenciaSede[] @relation("TransferenciaOrigen")
  transferenciasDestino TransferenciaSede[] @relation("TransferenciaDestino")
  reservasGrupales  ReservaGrupal[]
}

model Usuario {
  id           Int      @id @default(autoincrement())
  sedeId       Int?
  sede         Sede?    @relation(fields: [sedeId], references: [id])
  nombre       String
  username     String   @unique
  email        String?  @unique
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  alquileresCreados    Alquiler[]        @relation("AlquilerCreadoPor")
  alquileresAnulados   Alquiler[]        @relation("AlquilerAnuladoPor")
  alquileresCobrados   Alquiler[]        @relation("AlquilerCobradoPor")
  pagosAlquilerCreados PagoAlquiler[]    @relation("PagoCreadoPor")
  tareasAsignadas      TareaLimpieza[]   @relation("TareaAsignadaA")
  turnosCaja           TurnoCaja[]
  movimientosStock     MovimientoStock[]
  ventasCreadas        Venta[]           @relation("VentaCreadaPor")
  ventasAnuladas       Venta[]           @relation("VentaAnuladaPor")
  mensajesEnviados     Mensaje[]         @relation("MensajeFrom")
  mensajesRecibidos    Mensaje[]         @relation("MensajeTo")
  anulacionesSolicitadas AnulacionRequest[] @relation("AnuReqSolic")
  anulacionesAprobadas   AnulacionRequest[] @relation("AnuReqAprob")
  transferenciasCreadas   TransferenciaSede[] @relation("TransferenciaCreada")
  transferenciasRecibidas TransferenciaSede[] @relation("TransferenciaRecibida")
  reservasGrupalesCreadas  ReservaGrupal[] @relation("ReservaGrupalCreadaPor")

  @@index([sedeId])
}

// ============================================================
// HABITACIONES
// ============================================================
enum EstadoHabitacion {
  DISPONIBLE
  OCUPADA
  ALISTANDO
  MANTENIMIENTO
  FUERA_SERVICIO
}

model Piso {
  id           Int      @id @default(autoincrement())
  sedeId       Int
  sede         Sede     @relation(fields: [sedeId], references: [id])
  numero       Int
  nombre       String?
  creadoEn     DateTime @default(now())

  habitaciones Habitacion[]

  @@unique([sedeId, numero])
  @@index([sedeId])
}

model Habitacion {
  id              Int               @id @default(autoincrement())
  sedeId          Int
  sede            Sede              @relation(fields: [sedeId], references: [id])
  pisoId          Int
  piso            Piso              @relation(fields: [pisoId], references: [id])
  numero          String
  descripcion     String?
  caracteristicas String?
  precioHora      Decimal           @db.Decimal(10, 2)
  precioNoche     Decimal           @db.Decimal(10, 2)
  estado          EstadoHabitacion  @default(DISPONIBLE)
  activa          Boolean           @default(true)
  creadoEn        DateTime          @default(now())

  alquileres      Alquiler[]
  tareasLimpieza  TareaLimpieza[]
  fotos           FotoHabitacion[]

  @@unique([sedeId, numero])
  @@index([sedeId, estado])
}

// Fotos de habitación. orden 1-4 = principales (se muestran en tarjeta),
// orden 5+ = extras (solo galería).
model FotoHabitacion {
  id            Int        @id @default(autoincrement())
  habitacionId  Int
  habitacion    Habitacion @relation(fields: [habitacionId], references: [id], onDelete: Cascade)
  path          String
  orden         Int        @default(99)
  creadoEn      DateTime   @default(now())

  @@index([habitacionId, orden])
}

// ============================================================
// PRODUCTOS (consumibles para venta)
// ============================================================
model Producto {
  id          Int      @id @default(autoincrement())
  sedeId      Int
  sede        Sede     @relation(fields: [sedeId], references: [id])
  nombre      String
  descripcion String?
  precio      Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  stockMinimo Int      @default(0)
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  consumos    ConsumoProducto[]
  movimientos MovimientoStock[]
  itemsVenta  ItemVenta[]
  transferenciasOrigen  TransferenciaItem[] @relation("TransferenciaItemOrigen")
  transferenciasDestino TransferenciaItem[] @relation("TransferenciaItemDestino")

  @@index([sedeId])
}

// ============================================================
// PRODUCTOS DE LIMPIEZA
// ============================================================
model ProductoLimpieza {
  id          Int      @id @default(autoincrement())
  sedeId      Int
  sede        Sede     @relation(fields: [sedeId], references: [id])
  nombre      String
  descripcion String?
  stock       Int      @default(0)
  stockMinimo Int      @default(0)
  unidad      String   @default("unidad")
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  usos        UsoProductoLimpieza[]

  @@index([sedeId])
}

// ============================================================
// ALQUILERES
// ============================================================
enum EstadoAlquiler {
  ACTIVO
  FINALIZADO
  ANULADO
}

enum MetodoPago {
  EFECTIVO
  VISA
  MASTERCARD
  YAPE
  PLIN
  OTRO
}

model Alquiler {
  id              Int             @id @default(autoincrement())
  sedeId          Int
  sede            Sede            @relation(fields: [sedeId], references: [id])
  habitacionId    Int
  habitacion      Habitacion      @relation(fields: [habitacionId], references: [id])
  turnoCajaId     Int?
  turnoCaja       TurnoCaja?      @relation(fields: [turnoCajaId], references: [id])

  // Si forma parte de una reserva corporativa/grupal
  reservaGrupalId Int?
  reservaGrupal   ReservaGrupal?  @relation(fields: [reservaGrupalId], references: [id])

  clienteNombre   String
  clienteDni      String
  clienteTelefono String?
  clienteFechaNacimiento DateTime?

  // Datos fiscales (para FACTURA con RUC)
  tipoComprobante         String?  // 'BOLETA' (default) o 'FACTURA'
  clienteRuc              String?
  clienteRazonSocial      String?
  clienteDireccionFiscal  String?

  fechaIngreso    DateTime
  fechaSalida     DateTime
  fechaSalidaReal DateTime?

  precioHabitacion Decimal        @db.Decimal(10, 2)
  totalProductos   Decimal        @db.Decimal(10, 2) @default(0)
  total            Decimal        @db.Decimal(10, 2)
  metodoPago       MetodoPago
  notas            String?

  estado          EstadoAlquiler  @default(ACTIVO)
  motivoAnulacion String?
  anuladoEn       DateTime?
  anuladoPorId    Int?
  anuladoPor      Usuario?        @relation("AlquilerAnuladoPor", fields: [anuladoPorId], references: [id])

  // Flags de operación diaria
  pagado          Boolean         @default(true)  // true = totalmente pagado
  montoPagado     Decimal         @db.Decimal(10, 2) @default(0)  // acumulado (puede ser parcial)
  pagadoEn        DateTime?
  turnoPagoId     Int?                            // turno del último cobro
  turnoPago       TurnoCaja?      @relation("AlquilerTurnoPago", fields: [turnoPagoId], references: [id])
  cobradoPorId    Int?
  cobradoPor      Usuario?        @relation("AlquilerCobradoPor", fields: [cobradoPorId], references: [id])

  amenitiesEntregados Boolean     @default(false) // chocolates/bienvenida
  amenitiesNotas      String?

  creadoPorId     Int
  creadoPor       Usuario         @relation("AlquilerCreadoPor", fields: [creadoPorId], references: [id])
  creadoEn        DateTime        @default(now())

  consumos        ConsumoProducto[]
  anulacionRequests AnulacionRequest[]
  pagos           PagoAlquiler[]

  @@index([sedeId, estado])
  @@index([habitacionId])
  @@index([turnoCajaId])
  @@index([reservaGrupalId])
}

model ReservaGrupal {
  id                     Int        @id @default(autoincrement())
  sedeId                 Int
  sede                   Sede       @relation(fields: [sedeId], references: [id])
  turnoCajaId            Int?
  turnoCaja              TurnoCaja? @relation(fields: [turnoCajaId], references: [id])

  // Datos de la empresa (siempre FACTURA con RUC)
  clienteRuc             String
  clienteRazonSocial     String
  clienteDireccionFiscal String?
  contactoNombre         String?
  contactoTelefono       String?

  fechaIngreso           DateTime
  fechaSalida            DateTime

  total                  Decimal    @db.Decimal(10, 2)
  metodoPago             MetodoPago
  notas                  String?
  estado                 EstadoAlquiler @default(ACTIVO)

  creadoPorId            Int
  creadoPor              Usuario    @relation("ReservaGrupalCreadaPor", fields: [creadoPorId], references: [id])
  creadoEn               DateTime   @default(now())

  alquileres             Alquiler[]

  @@index([sedeId, estado])
  @@index([clienteRuc])
}

model ConsumoProducto {
  id           Int       @id @default(autoincrement())
  alquilerId   Int
  alquiler     Alquiler  @relation(fields: [alquilerId], references: [id], onDelete: Cascade)
  productoId   Int
  producto     Producto  @relation(fields: [productoId], references: [id])
  cantidad     Int
  precioUnit   Decimal   @db.Decimal(10, 2)
  subtotal     Decimal   @db.Decimal(10, 2)
  creadoEn     DateTime  @default(now())

  @@index([alquilerId])
  @@index([productoId])
}

// ============================================================
// STOCK (historial)
// ============================================================
enum TipoMovimiento {
  ENTRADA
  SALIDA_VENTA
  SALIDA_LIMPIEZA
  AJUSTE
  ANULACION
  TRANSFERENCIA_SALIDA
  TRANSFERENCIA_ENTRADA
}

enum EstadoTransferencia {
  ENVIADA
  RECIBIDA
  RECHAZADA
  CANCELADA
}

model TransferenciaSede {
  id              Int                  @id @default(autoincrement())
  sedeOrigenId    Int
  sedeOrigen      Sede                 @relation("TransferenciaOrigen", fields: [sedeOrigenId], references: [id])
  sedeDestinoId   Int
  sedeDestino     Sede                 @relation("TransferenciaDestino", fields: [sedeDestinoId], references: [id])

  estado          EstadoTransferencia  @default(ENVIADA)
  notas           String?

  creadoPorId     Int
  creadoPor       Usuario              @relation("TransferenciaCreada", fields: [creadoPorId], references: [id])
  creadoEn        DateTime             @default(now())

  recibidoPorId   Int?
  recibidoPor     Usuario?             @relation("TransferenciaRecibida", fields: [recibidoPorId], references: [id])
  recibidoEn      DateTime?

  motivoRechazo   String?

  items           TransferenciaItem[]

  @@index([sedeOrigenId, estado])
  @@index([sedeDestinoId, estado])
}

model TransferenciaItem {
  id               Int               @id @default(autoincrement())
  transferenciaId  Int
  transferencia    TransferenciaSede @relation(fields: [transferenciaId], references: [id], onDelete: Cascade)

  productoOrigenId  Int
  productoOrigen    Producto          @relation("TransferenciaItemOrigen", fields: [productoOrigenId], references: [id])

  productoDestinoId Int?
  productoDestino   Producto?         @relation("TransferenciaItemDestino", fields: [productoDestinoId], references: [id])

  nombreProducto   String
  precio           Decimal           @db.Decimal(10, 2)
  cantidad         Int

  @@index([transferenciaId])
}

// Historial de cobros individuales de un alquiler.
// Soporta pagos parciales: un mismo alquiler puede tener múltiples PagoAlquiler
// (ej. 20 en turno1 + 20 en turno2 = total 40). Cada cierre de caja suma los
// PagoAlquiler con su propio turnoCajaId.
model PagoAlquiler {
  id           Int        @id @default(autoincrement())
  alquilerId   Int
  alquiler     Alquiler   @relation(fields: [alquilerId], references: [id], onDelete: Cascade)
  turnoCajaId  Int
  turnoCaja    TurnoCaja  @relation("PagoTurno", fields: [turnoCajaId], references: [id])
  usuarioId    Int
  usuario      Usuario    @relation("PagoCreadoPor", fields: [usuarioId], references: [id])
  monto        Decimal    @db.Decimal(10, 2)
  metodoPago   MetodoPago
  fecha        DateTime   @default(now())

  @@index([alquilerId])
  @@index([turnoCajaId])
}

model MovimientoStock {
  id          Int              @id @default(autoincrement())
  productoId  Int?
  producto    Producto?        @relation(fields: [productoId], references: [id])
  tipo        TipoMovimiento
  cantidad    Int
  referencia  String?
  usuarioId   Int
  usuario     Usuario          @relation(fields: [usuarioId], references: [id])
  creadoEn    DateTime         @default(now())

  @@index([productoId])
}

// ============================================================
// LIMPIEZA
// ============================================================
enum EstadoTareaLimpieza {
  PENDIENTE
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

model TareaLimpieza {
  id             Int                 @id @default(autoincrement())
  sedeId         Int
  sede           Sede                @relation(fields: [sedeId], references: [id])
  habitacionId   Int
  habitacion     Habitacion          @relation(fields: [habitacionId], references: [id])
  asignadaAId    Int?
  asignadaA      Usuario?            @relation("TareaAsignadaA", fields: [asignadaAId], references: [id])

  estado         EstadoTareaLimpieza @default(PENDIENTE)
  iniciadaEn     DateTime?
  completadaEn   DateTime?
  notas          String?

  creadaEn       DateTime            @default(now())

  fotos          FotoLimpieza[]
  productosUsados UsoProductoLimpieza[]

  @@index([sedeId, estado])
  @@index([asignadaAId])
}

model FotoLimpieza {
  id         Int           @id @default(autoincrement())
  tareaId    Int
  tarea      TareaLimpieza @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  path       String
  subidaEn   DateTime      @default(now())

  @@index([tareaId])
}

model UsoProductoLimpieza {
  id          Int              @id @default(autoincrement())
  tareaId     Int
  tarea       TareaLimpieza    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  productoId  Int
  producto    ProductoLimpieza @relation(fields: [productoId], references: [id])
  cantidad    Int
  creadoEn    DateTime         @default(now())

  @@index([tareaId])
}

// ============================================================
// CAJA POR TURNO
// ============================================================
enum EstadoTurno {
  ABIERTO
  CERRADO
}

model TurnoCaja {
  id             Int         @id @default(autoincrement())
  sedeId         Int
  sede           Sede        @relation(fields: [sedeId], references: [id])
  usuarioId      Int
  usuario        Usuario     @relation(fields: [usuarioId], references: [id])

  abiertoEn      DateTime    @default(now())
  cerradoEn      DateTime?
  estado         EstadoTurno @default(ABIERTO)

  totalEfectivo  Decimal     @db.Decimal(10, 2) @default(0)
  totalVisa      Decimal     @db.Decimal(10, 2) @default(0)
  totalMaster    Decimal     @db.Decimal(10, 2) @default(0)
  totalYape      Decimal     @db.Decimal(10, 2) @default(0)
  totalPlin      Decimal     @db.Decimal(10, 2) @default(0)
  totalOtro      Decimal     @db.Decimal(10, 2) @default(0)
  totalGeneral   Decimal     @db.Decimal(10, 2) @default(0)
  notas          String?

  alquileres     Alquiler[]
  alquileresCobrados Alquiler[] @relation("AlquilerTurnoPago")
  ventas         Venta[]
  reservasGrupales ReservaGrupal[]
  pagosAlquiler  PagoAlquiler[] @relation("PagoTurno")

  @@index([sedeId, estado])
  @@index([usuarioId])
}

// ============================================================
// VENTA DIRECTA DE PRODUCTOS (sin alquiler)
// ============================================================
enum EstadoVenta {
  ACTIVA
  ANULADA
}

model Venta {
  id               Int         @id @default(autoincrement())
  sedeId           Int
  sede             Sede        @relation(fields: [sedeId], references: [id])
  turnoCajaId      Int
  turnoCaja        TurnoCaja   @relation(fields: [turnoCajaId], references: [id])

  usuarioId        Int
  usuario          Usuario     @relation("VentaCreadaPor", fields: [usuarioId], references: [id])

  metodoPago       MetodoPago
  total            Decimal     @db.Decimal(10, 2)
  notas            String?

  estado           EstadoVenta @default(ACTIVA)
  motivoAnulacion  String?
  anuladoEn        DateTime?
  anuladoPorId     Int?
  anuladoPor       Usuario?    @relation("VentaAnuladaPor", fields: [anuladoPorId], references: [id])

  creadoEn         DateTime    @default(now())
  items            ItemVenta[]

  @@index([sedeId, estado])
  @@index([turnoCajaId])
}

model ItemVenta {
  id          Int      @id @default(autoincrement())
  ventaId     Int
  venta       Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId  Int
  producto    Producto @relation(fields: [productoId], references: [id])
  cantidad    Int
  precioUnit  Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  creadoEn    DateTime @default(now())

  @@index([ventaId])
  @@index([productoId])
}

// ============================================================
// CHAT & ANULACIONES
// ============================================================
model Mensaje {
  id        Int      @id @default(autoincrement())
  sedeId    Int
  sede      Sede     @relation(fields: [sedeId], references: [id])
  fromId    Int
  from      Usuario  @relation("MensajeFrom", fields: [fromId], references: [id])
  toId      Int
  to        Usuario  @relation("MensajeTo", fields: [toId], references: [id])
  texto     String
  tipo      String   @default("TEXTO")
  metadata  Json?
  leido     Boolean  @default(false)
  leidoEn   DateTime?
  creadoEn  DateTime @default(now())

  @@index([toId, leido])
  @@index([fromId, toId, creadoEn])
  @@index([sedeId])
}

model AnulacionRequest {
  id             Int       @id @default(autoincrement())
  sedeId         Int
  sede           Sede      @relation(fields: [sedeId], references: [id])
  alquilerId     Int
  alquiler       Alquiler  @relation(fields: [alquilerId], references: [id])
  solicitanteId  Int
  solicitante    Usuario   @relation("AnuReqSolic", fields: [solicitanteId], references: [id])
  motivo         String
  estado         String    @default("PENDIENTE")
  respuestaAdmin String?
  aprobadorId    Int?
  aprobador      Usuario?  @relation("AnuReqAprob", fields: [aprobadorId], references: [id])
  respondidoEn   DateTime?
  creadoEn       DateTime  @default(now())

  @@index([sedeId, estado])
  @@index([solicitanteId])
}

// ============================================================
// CONFIG (singleton id=1) — datos empresa + tokens API externas
// ============================================================
model AppConfig {
  id                Int      @id @default(1)
  empresaNombre     String?
  empresaRuc        String?
  empresaDireccion  String?
  empresaTelefono   String?
  empresaEmail      String?
  logoPath          String?
  apiDniToken       String?
  apiRucToken       String?
  apiDniUrl         String   @default("https://dniruc.apisperu.com/api/v1/dni")
  apiRucUrl         String   @default("https://dniruc.apisperu.com/api/v1/ruc")
  actualizadoEn     DateTime @updatedAt
  creadoEn          DateTime @default(now())
}
