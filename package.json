{
  "name": "hotel-system",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "backend": "npm run start:dev --workspace backend",
    "frontend": "npm run dev --workspace frontend",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
